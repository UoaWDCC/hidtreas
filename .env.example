# Copy to .env for local development. In production these are set as Fly secrets
# (`fly secrets set KEY=value -a hidtreas`) — do NOT commit real values.

# MongoDB (Atlas) connection string
DATABASE_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Payload encryption secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# S3-compatible media storage
AWS_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# Public site URL — used for live preview and metadata. Inlined at BUILD time.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Shared secret for the on-publish cache revalidation hook (-> /api/revalidate).
# REQUIRED in production. Runtime-only (NOT a build arg). If unset, the afterChange
# hook silently no-ops and edits only appear after the 30-60 min ISR timer.
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=
